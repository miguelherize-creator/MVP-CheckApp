{
  "info": {
    "_postman_id": "a1b2c3d4-checkapp-mvp-001",
    "name": "CheckApp MVP — Flujo 1 y 2",
    "description": "**Flujo 1:** ejecuta las peticiones en orden (1 → 5). Genera un email nuevo en Register y guarda tokens.\n\n**Flujo 2:** asigna en variables de colección `email` y `password` (mismo usuario que en Flujo 1, o créalo a mano), luego ejecuta la carpeta en orden.\n\nVariables de colección: `baseUrl` (por defecto http://localhost:3000), `password` (Abcd1234).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "password", "value": "Abcd1234" },
    { "key": "email", "value": "" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "Flujo 1 — Register → Me → Login → Me → Refresh",
      "item": [
        {
          "name": "1. Register",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const email = 'flow1_' + Date.now() + '@postman.test';",
                  "pm.collectionVariables.set('email', email);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200/201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Tiene accessToken y refreshToken', function () {",
                  "    pm.expect(json.accessToken).to.be.a('string');",
                  "    pm.expect(json.refreshToken).to.be.a('string');",
                  "    pm.expect(json.user).to.be.an('object');",
                  "});",
                  "pm.collectionVariables.set('accessToken', json.accessToken);",
                  "pm.collectionVariables.set('refreshToken', json.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Usuario Postman\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"acceptTerms\": true\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "2. GET users/me (token del register)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Email coincide con variable', function () {",
                  "    pm.expect(json.email).to.eql(pm.collectionVariables.get('email'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/users/me"
          }
        },
        {
          "name": "3. Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 o 201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', json.accessToken);",
                  "pm.collectionVariables.set('refreshToken', json.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "4. GET users/me (token del login)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Tiene email', function () { pm.expect(json.email).to.exist; });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/users/me"
          }
        },
        {
          "name": "5. Refresh (opcional)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 o 201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Nuevo accessToken', function () { pm.expect(json.accessToken).to.be.a('string'); });",
                  "if (json.refreshToken) {",
                  "    pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "}",
                  "pm.collectionVariables.set('accessToken', json.accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/refresh"
          }
        }
      ]
    },
    {
      "name": "Flujo 2 — Solo Login → Me",
      "item": [
        {
          "name": "0. Preparar usuario (register una vez)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const email = 'flow2_' + Date.now() + '@postman.test';",
                  "pm.collectionVariables.set('email', email);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Usuario creado', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "pm.test('Guarda email para el login', function () {",
                  "    pm.expect(pm.collectionVariables.get('email')).to.include('@postman.test');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Usuario Flujo 2\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"acceptTerms\": true\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "1. Login",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const e = pm.collectionVariables.get('email');",
                  "if (!e) { throw new Error('Sin email: ejecuta antes \"0. Preparar usuario\" o define la variable email en la colección.'); }"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 o 201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', json.accessToken);",
                  "pm.collectionVariables.set('refreshToken', json.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "2. GET users/me",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Email esperado', function () {",
                  "    pm.expect(json.email).to.eql(pm.collectionVariables.get('email'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/users/me"
          }
        }
      ]
    }
  ]
}
