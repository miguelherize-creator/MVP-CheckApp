# PostgreSQL (URL completa)
DATABASE_URL=postgresql://checkapp:checkapp@localhost:5432/checkapp

# JWT access (corto)
JWT_SECRET=cambiar-en-produccion-minimo-32-caracteres
JWT_EXPIRES_IN=15m

# Refresh opaco en BD (duración en días)
REFRESH_EXPIRES_DAYS=7

# Recuperación de contraseña
PASSWORD_RESET_EXPIRES_MINUTES=60
# Plantilla: debe incluir {{token}} o se añade ?token= al final
PASSWORD_RESET_URL_TEMPLATE=myapp://reset-password?token={{token}}

NODE_ENV=development
PORT=3000

# Orígenes web separados por coma (opcional)
CORS_ORIGIN=http://localhost:3001,http://localhost:19006
